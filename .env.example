# Supabase — same project as the PACT bot
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...

# Service role for server-side queries (manually scoped by pt_id).
# Server-only — Next.js does NOT expose this to the browser because it
# lacks the NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# Base URL — used by the magic-link callback so links resolve to the right host
# In Vercel this is auto-set by NEXT_PUBLIC_VERCEL_URL but we set it explicitly for safety
NEXT_PUBLIC_SITE_URL=http://localhost:3000
